##############################
# - CF_TOKEN (用于 Cloudflare API 访问)
# - GITHUB_TOKEN (用于 github API 访问)
# - BARK_TOKEN (用于 Bark 通知)
# - TG_BOT_TOKEN (用于 Telegram 通知)
# - TG_CHAT_ID (用于 Telegram 通知的聊天 ID，指示接收通知的目标)
##############################
CF_TOKEN=""
GITHUB_TOKEN="github_pat_"
BARK_TOKEN=""
TG_BOT_TOKEN=""
TG_CHAT_ID=""

##############################
# - SRV_NAME (服务名称，用于通知)
# - GITHUB_REPO (存储证书私有仓库的完整名称，例如 'owner/repo')
# - FULL_DOMAIN (需要更新的完整域名)
# - NIC (指定用于获取当前 IP 地址的网络接口)
# - CERTIFICATE_FILE (SSL/TLS 证书文件路径)
# - CERTIFICATE_KEY_FILE (SSL/TLS 证书密钥文件路径)
##############################
SRV_NAME="Router 01"
GITHUB_REPO="22p/cert"
FULL_DOMAIN="abc.example.com"
NIC=ppp0
CERTIFICATE_FILE="/opt/podman/cert/fullchain.pem"
CERTIFICATE_KEY_FILE="/opt/podman/cert/private.key"
HTTPS_ALPN="h3"
HTTPS_PORT="443"
ECH=""
